# Discord OAuth App — https://discord.com/developers/applications
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret

# Must match exactly what you set in Discord OAuth2 Redirects
DISCORD_REDIRECT_URI=https://vault-os-api.onrender.com/auth/discord/callback

# Frontend origin — your Cloudflare Pages URL
FRONTEND_URL=https://vault-os.pages.dev

# JWT signing secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_char_hex

# Discord user IDs allowed admin access (comma-separated)
ADMIN_DISCORD_IDS=your_discord_user_id

# Port (Render sets this automatically)
PORT=3000
